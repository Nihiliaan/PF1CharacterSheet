rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() { return request.auth != null; }
    function isVerified() { return isSignedIn() && request.auth.token.email_verified == true; }
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }

    // --- Character Rules ---
    function isValidCharacter(data) {
      return data.keys().hasAll(['name', 'ownerId', 'data', 'createdAt', 'updatedAt'])
        && data.name is string && data.name.size() > 0 && data.name.size() <= 200
        && data.ownerId is string && data.ownerId.size() <= 128
        && data.data is map 
        && (data.get('isPublic', false) is bool)
        && data.createdAt is timestamp
        && data.updatedAt is timestamp
        && (data.get('folderId', null) == null || data.get('folderId', null) is string);
    }

    match /characters/{characterId} {
      allow get: if isValidId(characterId) && (resource.data.get('isPublic', false) == true || isOwner(resource.data.ownerId));
      allow list: if isSignedIn() && resource.data.ownerId == request.auth.uid;
      
      allow create: if isValidId(characterId) 
        && isVerified()
        && isValidCharacter(incoming())
        && incoming().ownerId == request.auth.uid
        && incoming().createdAt == request.time
        && incoming().updatedAt == request.time;

      allow update: if isValidId(characterId)
        && isVerified()
        && isOwner(existing().ownerId)
        && isValidCharacter(incoming())
        && incoming().createdAt == existing().createdAt
        && incoming().ownerId == existing().ownerId
        && (incoming().updatedAt == request.time || !incoming().diff(existing()).affectedKeys().hasAny(['updatedAt']))
        && (incoming().diff(existing()).affectedKeys().hasOnly(['name', 'data', 'isPublic', 'updatedAt', 'folderId', 'ownerId']));

      allow delete: if isValidId(characterId) && isVerified() && isOwner(existing().ownerId);
    }

    // --- Folder Rules ---
    function isValidFolder(data) {
      return data.keys().hasAll(['name', 'ownerId', 'createdAt'])
        && data.name is string && data.name.size() > 0 && data.name.size() <= 100
        && data.ownerId is string && data.ownerId.size() <= 128
        && data.createdAt is timestamp
        && (data.get('parentId', null) == null || data.get('parentId', null) is string)
        && (data.get('updatedAt', null) == null || data.get('updatedAt', null) is timestamp);
    }

    match /folders/{folderId} {
      allow get: if isValidId(folderId) && isOwner(existing().ownerId);
      allow list: if isSignedIn() && resource.data.ownerId == request.auth.uid;
      
      allow create: if isValidId(folderId) 
        && isVerified()
        && isValidFolder(incoming())
        && incoming().ownerId == request.auth.uid
        && incoming().createdAt == request.time;

      allow update: if isValidId(folderId) 
        && isVerified()
        && isOwner(existing().ownerId)
        && isValidFolder(incoming())
        && incoming().createdAt == existing().createdAt
        && incoming().ownerId == existing().ownerId
        && (incoming().diff(existing()).affectedKeys().hasOnly(['name', 'parentId', 'updatedAt', 'ownerId']));

      allow delete: if isValidId(folderId) && isVerified() && isOwner(existing().ownerId);
    }

    // --- User Rules ---
    function isValidUser(data) {
      return data.keys().hasAll(['displayName', 'email', 'linkedProviders', 'lastLogin'])
        && data.displayName is string && data.displayName.size() > 0 && data.displayName.size() <= 100
        && (data.email == null || (data.email is string && data.email.size() <= 256))
        && data.linkedProviders is list
        && data.lastLogin is string;
    }

    match /users/{userId} {
      allow get: if isOwner(userId);
      allow create: if isOwner(userId) && isValidUser(incoming());
      allow update: if isOwner(userId) && isValidUser(incoming())
        && incoming().diff(existing()).affectedKeys().hasOnly(['displayName', 'email', 'linkedProviders', 'lastLogin', 'photoURL']);
    }
  }
}
