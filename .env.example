# Gemini API Key
# For AI Studio compatibility, you can fill this or rely on user-entered keys in the UI
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# App URL
APP_URL="MY_APP_URL"

# Firebase Configuration
# These are exposed to the client, so VITE_ prefix is required for Vite projects.
# Note: Client-side Firebase keys are generally safe to be public if security rules are set.
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_MEASUREMENT_ID=
VITE_FIREBASE_DATABASE_ID=
