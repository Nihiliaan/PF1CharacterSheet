rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() { return request.auth != null; }
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }

    // --- Character Rules ---
    // Pillar 2: Validation Blueprint
    function isValidCharacter(data) {
      return data.keys().hasAll(['name', 'ownerId', 'data', 'createdAt', 'updatedAt'])
        && data.name is string && data.name.size() > 0 && data.name.size() <= 200
        && data.ownerId is string && data.ownerId == request.auth.uid // Pillar 2: Identity Integrity
        && data.data is map 
        && (!('isPublic' in data) || data.isPublic is bool)
        && data.createdAt is timestamp
        && data.updatedAt is timestamp
        && (!('folderId' in data) || data.folderId == null || data.folderId is string);
    }

    match /characters/{characterId} {
      allow get: if isValidId(characterId) && (existing().get('isPublic', false) == true || isOwner(existing().ownerId));
      allow list: if isSignedIn() && resource.data.ownerId == request.auth.uid; // Pillar 8: Secure List Queries
      
      allow create: if isValidId(characterId) 
        && isValidCharacter(incoming())
        && incoming().createdAt == request.time
        && incoming().updatedAt == request.time;

      // Pillar 4 & 6: Action-Based Update Pattern, Pillar 2: Validation Blueprint (wrapped)
      allow update: if isValidId(characterId)
        && isOwner(existing().ownerId)
        && isValidCharacter(incoming())
        && incoming().createdAt == existing().createdAt // Pillar 9: Immortal Field
        && incoming().ownerId == existing().ownerId // Pillar 9: Immortal Field
        && incoming().updatedAt == request.time // Pillar 10: Temporal Integrity
        && (incoming().diff(existing()).affectedKeys().hasOnly(['name', 'data', 'isPublic', 'updatedAt', 'folderId']));

      allow delete: if isValidId(characterId) && isOwner(existing().ownerId);
    }

    // --- Folder Rules ---
    function isValidFolder(data) {
      return data.keys().hasAll(['name', 'ownerId', 'createdAt'])
        && data.name is string && data.name.size() > 0 && data.name.size() <= 100
        && data.ownerId is string && data.ownerId == request.auth.uid
        && data.createdAt is timestamp
        && (!('parentId' in data) || data.parentId == null || data.parentId is string)
        && (!('updatedAt' in data) || data.updatedAt is timestamp);
    }

    match /folders/{folderId} {
      allow get: if isValidId(folderId) && isOwner(existing().ownerId);
      allow list: if isSignedIn() && resource.data.ownerId == request.auth.uid;
      
      allow create: if isValidId(folderId) 
        && isValidFolder(incoming())
        && incoming().createdAt == request.time;

      allow update: if isValidId(folderId) && isOwner(existing().ownerId)
        && isValidFolder(incoming())
        && incoming().createdAt == existing().createdAt
        && incoming().ownerId == existing().ownerId
        && (incoming().updatedAt == request.time || incoming().updatedAt == existing().updatedAt)
        && (incoming().diff(existing()).affectedKeys().hasOnly(['name', 'parentId', 'updatedAt']));

      allow delete: if isValidId(folderId) && isOwner(existing().ownerId);
    }

    // --- User Rules ---
    function isValidUser(data) {
      return data.keys().hasAll(['displayName', 'email', 'linkedProviders', 'lastLogin'])
        && data.displayName is string && data.displayName.size() > 0 && data.displayName.size() <= 100
        && (data.email == null || (data.email is string && data.email.size() <= 256))
        && data.linkedProviders is list
        && data.lastLogin is string;
    }

    match /users/{userId} {
      allow get: if isOwner(userId);
      allow create: if isOwner(userId) && isValidUser(incoming());
      allow update: if isOwner(userId) && isValidUser(incoming())
        && incoming().diff(existing()).affectedKeys().hasOnly(['displayName', 'email', 'linkedProviders', 'lastLogin', 'photoURL']);
    }
  }
}
